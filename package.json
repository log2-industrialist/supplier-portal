{
  "name": "supplier-portal",
  "version": "1.2.3",
  "description": "Supplier management portal for log2-industrialist procurement team",
  "repository": "https://github.com/log2-industrialist/supplier-portal",
  "license": "MIT",
  "private": true,
  "dependencies": {
    "@sap/cds": "^7.6.0",
    "@sap/xssec": "^3.6.1",
    "@sap/audit-logging": "^5.7.2",
    "@sap/hdbext": "^7.7.1",
    "express": "^4.18.2",
    "hdb": "^0.19.5",
    "passport": "^0.7.0",
    "axios": "^1.6.5"
  },
  "devDependencies": {
    "@sap/cds-dk": "^7.6.0",
    "@sap/eslint-plugin-cds": "^2.6.5",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "build": "cds build --production",
    "deploy": "./scripts/deploy.sh",
    "test": "jest"
  },
  "cds": {
    "requires": {
      "auth": "xsuaa",
      "db": "hana",
      "S4HANA": {
        "kind": "odata",
        "model": "srv/external/S4HANA",
        "credentials": {
          "destination": "S4HANA_OD",
          "path": "/sap/opu/odata/sap/API_SUPPLIER_SRV"
        }
      }
    }
  }
}
